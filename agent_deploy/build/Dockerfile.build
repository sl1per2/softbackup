FROM ubuntu:22.04

RUN apt-get update && apt-get install -y \
    cmake make gcc g++ \
    gcc-aarch64-linux-gnu g++-aarch64-linux-gnu \
    mingw-w64 \
    libssl-dev libcurl4-openssl-dev \
    protobuf-compiler libprotobuf-dev \
    libsqlite3-dev libspdlog-dev \
    git pkg-config \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY . .

CMD ["./build_all.sh"]
