FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y software-properties-common && \
    add-apt-repository -y universe && \
    apt-get update && apt-get install -y \
    cmake make g++ \
    gcc-aarch64-linux-gnu g++-aarch64-linux-gnu \
    binutils-aarch64-linux-gnu \
    libssl-dev libcurl4-openssl-dev \
    protobuf-compiler libprotobuf-dev \
    libsqlite3-dev libspdlog-dev \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

COPY core/include/ /build/core/include/
COPY core/src/ /build/core/src/
COPY core/tests/ /build/core/tests/
COPY core/CMakeLists.txt /build/core/
COPY proto/ /build/proto/
COPY agent_deploy/build/build_arm64.sh /build/build_arm64.sh
RUN chmod +x /build/build_arm64.sh
CMD ["/build/build_arm64.sh"]
